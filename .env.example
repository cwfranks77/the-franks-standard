# Copy to .env (never commit .env with real values).

# Operator unlock phrase: same value you type after 5 home-page logo taps (trimmed on compare). Opens owner toolkit at /ops/panel.
# Build-time public variable—use a long random string. In GitHub: set secret NUXT_PUBLIC_OPS_ACCESS_KEY for Actions.
NUXT_PUBLIC_OPS_ACCESS_KEY=

# Stripe Payment Link URLs (create each link in https://dashboard.stripe.com/ → Product catalog → Payment links).
# Paste full https://buy.stripe.com/... or payment link URL. Rebuild after changing.
NUXT_PUBLIC_PAY_LISTING_FEE_URL=
NUXT_PUBLIC_PAY_PRO_SELLER_URL=
NUXT_PUBLIC_PAY_ORDER_DEPOSIT_URL=
NUXT_PUBLIC_PAY_DISPUTE_FEE_URL=

# Canonical site URL (no trailing slash). Used for Open Graph URLs and og:image base.
NUXT_PUBLIC_SITE_URL=https://thefranksstandard.com

# Optional: full URL to social preview image (e.g. PNG). Default is SITE_URL + /logo.svg
# NUXT_PUBLIC_OG_IMAGE=https://thefranksstandard.com/logo.png

# Optional: Telegram message to YOUR phone when a deploy finishes (GitHub Actions runs notify-telegram.cjs).
# 1) Create a bot with @BotFather, copy TELEGRAM_BOT_TOKEN.
# 2) Open Telegram, start a chat with your bot, send any message.
# 3) Open https://api.telegram.org/bot<TOKEN>/getUpdates in a browser — find "chat":{"id":123456789 — that is TELEGRAM_NOTIFY_CHAT_ID.
# 4) Add both as GitHub repo Secrets (Settings → Secrets and variables → Actions) on cwfranks77/the-franks-standard.
# Cursor AI cannot SMS you; this is how you get a ping on your phone when the site publishes.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_NOTIFY_CHAT_ID=
