# Copy to .env (never commit .env with real values).

# Supabase (Project Settings -> API: Project URL + anon public key)
# Vercel may warn that NUXT_PUBLIC_SUPABASE_KEY "exposes sensitive material" — that is OK for the
# anon (public) key: it is meant to ship in the browser. Security is Row Level Security in Supabase.
# NEVER put the service_role key here or in any NUXT_PUBLIC_* variable.
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_KEY=

# Operator unlock phrase: same value you type after 5 home-page logo taps. Opens owner toolkit at /ops/panel.
#
# SECURITY: only the SHA-256 HASH ships to the browser. Plaintext is never shipped.
# Set the hash of your phrase here. Compute it with:
#   node scripts/hash-ops-key.cjs "your secret phrase here"
# In Vercel / GitHub Actions: set NUXT_PUBLIC_OPS_ACCESS_KEY_HASH only and remove the legacy plaintext var.
NUXT_PUBLIC_OPS_ACCESS_KEY_HASH=
#
# Legacy plaintext fallback (kept for backward compatibility). If both are set, the HASH wins.
# Build-time only: nuxt.config.ts hashes this at build so plaintext never reaches the bundle. Even so,
# REMOVE this once you have set the _HASH variable above (it just protects you from typos).
NUXT_PUBLIC_OPS_ACCESS_KEY=

# Stripe Payment Link URLs (create each link in https://dashboard.stripe.com/ → Product catalog → Payment links).
# Paste full https://buy.stripe.com/... or payment link URL. Rebuild after changing.
NUXT_PUBLIC_PAY_LISTING_FEE_URL=
NUXT_PUBLIC_PAY_PRO_SELLER_URL=
NUXT_PUBLIC_PAY_ORDER_DEPOSIT_URL=
NUXT_PUBLIC_PAY_DISPUTE_FEE_URL=

# Canonical site URL (no trailing slash). Used for Open Graph URLs, og:image, and Supabase email redirect.
NUXT_PUBLIC_SITE_URL=https://thefranksstandard.com
#
# Supabase: Authentication → URL configuration → Redirect URLs — add:
#   https://thefranksstandard.com/auth/verify
#   http://localhost:3000/auth/verify   (optional, local dev)
# Branded verification email: Project Settings → Auth → Custom SMTP; Authentication → Email templates.

# Customer service toll-free number (displayed on Support, Contact, and AI chat).
# Buy a number in Twilio (twilio.com/console/phone-numbers) and paste it here.
NUXT_PUBLIC_CUSTOMER_SERVICE_PHONE=1-800-TFS-HELP

# Twilio (AI phone agent, call recording, monitoring).
# Create account at twilio.com, get these from twilio.com/console
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Optional: full URL to social preview image (e.g. PNG). Default is SITE_URL + /logo.svg
# NUXT_PUBLIC_OG_IMAGE=https://thefranksstandard.com/franks-pavilion.png

# Optional: Telegram message to YOUR phone when a deploy finishes (GitHub Actions runs notify-telegram.cjs).
# 1) Create a bot with @BotFather, copy TELEGRAM_BOT_TOKEN.
# 2) Open Telegram, start a chat with your bot, send any message.
# 3) Open https://api.telegram.org/bot<TOKEN>/getUpdates in a browser — find "chat":{"id":123456789 — that is TELEGRAM_NOTIFY_CHAT_ID.
# 4) Add both as GitHub repo Secrets (Settings → Secrets and variables → Actions) on cwfranks77/the-franks-standard.
# Cursor AI cannot SMS you; this is how you get a ping on your phone when the site publishes.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_NOTIFY_CHAT_ID=

# --- Email campaigns (SendGrid): npm run email:campaign ---
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=info@thefranksstandard.com
# SENDGRID_FROM_NAME=The Franks Standard

# --- Direct mail (Lob postcards): npm run mail:lob-sample ---
# LOB_API_KEY=
# LOB_POSTCARD_FRONT_URL=

# --- Search indexing ping: npm run seo:ping ---
# INDEXNOW_KEY=

# --- Social launch (optional): npm run post:social from repo root ---
# TELEGRAM_CHANNEL_ID=   (channel id, often -100…; bot must be admin on the channel)
# FACEBOOK_PAGE_ID=1018067851385482
# FACEBOOK_PAGE_ACCESS_TOKEN=   (long-lived Page token; use scripts/push-facebook-long-lived.ps1 once)
# FACEBOOK_APP_ID=               (Meta App settings → Basic)
# FACEBOOK_APP_SECRET=          (never commit; GitHub secret or local env only)
# FACEBOOK_USER_ACCESS_TOKEN=   (optional: short Explorer user token for exchange)
# See docs/META-FACEBOOK-SETUP.md
# X_API_KEY=  X_API_SECRET=  X_ACCESS_TOKEN=  X_ACCESS_SECRET=

# --- Full dropship automation (Inventory Source + Supabase Edge Functions) ---
# Set these as Supabase Edge Function secrets (NOT NUXT_PUBLIC vars):
#   supabase secrets set INVENTORY_SOURCE_API_KEY=...
#   supabase secrets set INVENTORY_SOURCE_WEBHOOK_SECRET=...
#   supabase secrets set INVENTORY_SOURCE_API_BASE=https://api.inventorysource.com
#
# Use these names in your secure function environment:
# INVENTORY_SOURCE_API_KEY=
# INVENTORY_SOURCE_WEBHOOK_SECRET=
# INVENTORY_SOURCE_API_BASE=https://api.inventorysource.com
# INVENTORY_SOURCE_ORDER_ENDPOINT=v1/orders
#
# Doba via Inventory Source (optional but recommended when providerKey is "doba")
# DOBA_INVENTORY_SOURCE_SUPPLIER_ID=
# DOBA_INVENTORY_SOURCE_WAREHOUSE_ID=
# DOBA_INVENTORY_SOURCE_ORDER_ENDPOINT=v1/orders
#
# Doba via FLXPOINT (recommended when Inventory Source direct API is unavailable)
# FLXPOINT_API_KEY=
# FLXPOINT_WEBHOOK_SECRET=
# FLXPOINT_API_BASE=https://api.flxpoint.com
# FLXPOINT_ORDER_ENDPOINT=api/orders
