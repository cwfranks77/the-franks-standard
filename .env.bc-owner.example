# BC Audio owner section — copy values into your deploy secrets / .env

# Supabase (required for owner data tables)
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Owner unlock (already used by ops panel)
NUXT_PUBLIC_OPS_ACCESS_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_WEBHOOK_SECRET=
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_DISTRIBUTOR_CONNECT_ACCOUNT_ID=

# Site
NUXT_PUBLIC_SITE_URL=https://bcpoweraudio.com
NOTIFICATION_EMAIL_FROM=no-reply@bcpoweraudio.com

# AI dispute triage (optional — rule-based fallback works without these)
AI_PROVIDER_API_KEY=
AI_PROVIDER_ENDPOINT=

# Auto-refund guardrails
NUXT_PUBLIC_BC_ACCOUNTS_REQUIRED=true
AUTO_REFUND_MAX_AMOUNT=200
