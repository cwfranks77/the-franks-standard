# Copy to .env in this folder (never commit .env with real values).

# Owner / operator unlock phrase for /owner tools dashboard.
# Same value as GitHub repo secret: NUXT_PUBLIC_OPS_ACCESS_KEY
# Local alias (optional): OWNER_SECRET_PASSPHRASE
#
# GitHub: cwfranks77/the-franks-standard → Settings → Secrets and variables → Actions
# Secrets on file: NUXT_PUBLIC_OPS_ACCESS_KEY and NUXT_PUBLIC_OPS_ACCESS_KEY_HASH
#
# To compute the hash only (for GitHub without plaintext):
#   node scripts/hash-ops-key.cjs "your operator phrase here"
NUXT_PUBLIC_OPS_ACCESS_KEY=

# Site URL (no trailing slash)
NUXT_PUBLIC_SITE_URL=https://thefranksstandard.com
