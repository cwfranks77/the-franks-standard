{
  "name": "the-franks-standard",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nuxt generate && node scripts/inject-spa-fallback.cjs && node scripts/patch-gh-pages-spa.cjs && node scripts/finish-pwa.cjs",
    "dev": "nuxt dev",
    "generate": "npm run build",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "post:social": "node scripts/post-franks-social.cjs",
    "x:rebrand": "node scripts/update-x-profile.cjs",
    "post:social:founders": "node scripts/post-franks-social.cjs --founders",
    "post:social:honor": "node scripts/post-franks-social.cjs --honor",
    "secrets:push-x": "powershell -ExecutionPolicy Bypass -File scripts/push-x-secrets.ps1",
    "setup:all": "powershell -ExecutionPolicy Bypass -File scripts/execute-all-setup.ps1",
    "email:campaign": "node scripts/send-email-campaign.cjs",
    "mail:lob-sample": "node scripts/lob-send-postcard.cjs",
    "seo:ping": "node scripts/seo-ping.cjs",
    "check:routes": "node scripts/check-site-routes.cjs",
    "secrets:check": "node scripts/secrets-check.cjs",
    "validate:facebook": "node scripts/validate-facebook-setup.cjs",
    "facebook:exchange": "node scripts/exchange-facebook-page-token.cjs",
    "facebook:long-lived": "node scripts/exchange-facebook-page-token.cjs --push-github",
    "notify:telegram": "node scripts/notify-telegram.cjs",
    "verify": "npm run generate",
    "env:vercel": "node scripts/push-vercel-env.cjs",
    "deploy:gh-pages": "npm run generate && npx --yes gh-pages@6.2.0 -d .output/public -t -m \"chore(gh-pages): static deploy\"",
    "stripe:webhook": "node scripts/wire-stripe-webhook.cjs",
    "stripe:reconcile": "node scripts/reconcile-stripe-orders.cjs",
    "health": "node scripts/health-check.cjs",
    "mail:test": "node scripts/test-mailbox.cjs",
    "mail:fix": "node scripts/apply-email-password.cjs",
    "namecheap:recover": "powershell -ExecutionPolicy Bypass -File scripts/namecheap-recover.ps1",
    "mail:set-now": "powershell -ExecutionPolicy Bypass -File scripts/set-mailbox-now.ps1",
    "ebay:easy": "powershell -ExecutionPolicy Bypass -File scripts/ebay-easy.ps1",
    "ebay:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-ebay-api.ps1",
    "ebay:secrets": "powershell -ExecutionPolicy Bypass -File scripts/push-ebay-api-secrets.ps1"
  },
  "dependencies": {
    "@nuxtjs/supabase": "^2.0.6",
    "@stripe/stripe-js": "^5.5.0",
    "nuxt": "^3.21.6",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@nuxt/devtools": "^2.3.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "form-data": "^4.0.0",
    "stripe": "^22.1.1",
    "typescript": "^5.7.0"
  }
}
