# The Franks Standard — Environment Example
# Copy to .env locally. Never commit secrets.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_ANON_KEY=

# Owner ops (SHA-256 hash of unlock phrase — not the phrase itself)
NUXT_OPS_ACCESS_KEY_HASH=
OPS_ACCESS_KEY_HASH=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email (SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=info@thefranksstandard.com
SENDGRID_FROM_NAME=The Franks Standard

# Cache (optional)
REDIS_URL=
NUXT_REDIS_URL=

# Site
SITE_URL=https://thefranksstandard.com
# Set to true only while storefronts should stay on home-page preview
NUXT_PUBLIC_COMING_SOON=false
NUXT_PUBLIC_SITE_URL=https://thefranksstandard.com

# Cron (GitHub Actions + Supabase Edge)
CRON_SECRET=

# Twilio / voice (optional — B&C and TFS voice lines)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
BC_VOICE_OWNER_PHONE=

# OpenAI (optional voice AI)
OPENAI_API_KEY=
